{
  "name": "solid-static",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./content": {
      "types": "./dist/content.d.ts",
      "default": "./dist/content.js"
    },
    "./image": {
      "types": "./dist/image.d.ts",
      "default": "./dist/image.jsx"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "default": "./dist/markdown.js"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "default": "./dist/render.jsx"
    },
    "./responsive-images": {
      "types": "./dist/responsive-images.d.ts",
      "default": "./dist/responsive-images.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    }
  },
  "peerDependencies": {
    "solid-js": "^1.9.14",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "js-yaml": "^5.2.1",
    "mdast-util-from-markdown": "^2.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.35.3",
    "unified": "11.0.5",
    "vite-plugin-solid": "^2.11.12"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.0",
    "oxlint": "^1.73.0",
    "remark-parse": "^11.0.0",
    "solid-js": "^1.9.14",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "^0.4.5",
      "onFail": "warn"
    }
  }
}
